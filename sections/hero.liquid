<section class="hero" style="background-image: url('{{ section.settings.background_image | image_url }}'); background-size: cover; background-position: center; padding: 6rem 2rem; text-align: center; color: white; text-shadow: 0 2px 4px rgba(0,0,0,0.3);">
  <div class="container">
    <h1 style="font-size: 3rem; margin-bottom: 1rem;">{{ section.settings.title }}</h1>
    <p style="font-size: 1.25rem; margin-bottom: 2rem;">{{ section.settings.subtitle }}</p>
    <a href="{{ section.settings.button_link }}" style="background-color: var(--accent-color); color: #000; padding: 0.75rem 2rem; text-decoration: none; border-radius: 4px; font-weight: 600; display: inline-block;">{{ section.settings.button_text }}</a>
  </div>
</section>

{% stylesheet %}
  .hero {
    min-height: 400px;
    display: flex;
    align-items: center;
    justify-content: center;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Hero",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Welcome to Our Greeting Card Wholesale"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Premium greeting cards for every occasion"
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background Image"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "Shop Now"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    }
  ],
  "presets": [
    {
      "name": "Hero"
    }
  ]
}
{% endschema %}
